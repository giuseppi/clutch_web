# ============================================
# Clutch Environment Variables
# Copy to server/.env and fill in values
# ============================================
#
# Local dev uses Docker (Postgres, Redis, MinIO) with the defaults below.
# Production uses Supabase (DB + Auth + Storage) + Upstash (Redis).
# The codebase auto-detects which mode to use based on which env vars are set.

# ── Database ──────────────────────────────────────────────
# Local dev: Docker PostgreSQL
DATABASE_URL="postgresql://clutch:clutch_dev@localhost:5432/clutch"
# Production (Supabase): uncomment and fill in both.
# DATABASE_URL uses the pooled connection (PgBouncer); DIRECT_URL bypasses it for migrations.
# DIRECT_URL="postgresql://postgres.[ref]:[pw]@db.[ref].supabase.co:5432/postgres"
# DATABASE_URL="postgresql://postgres.[ref]:[pw]@[ref].pooler.supabase.co:6543/postgres?pgbouncer=true"

# ── Redis ─────────────────────────────────────────────────
# Local dev: Docker Redis
REDIS_URL="redis://localhost:6379"
# Production (Upstash): use the rediss:// URL from Upstash console
# REDIS_URL="rediss://default:<password>@<region>.upstash.io:6379"

# ── S3 / Object Storage ──────────────────────────────────
# Local dev: Docker MinIO
AWS_ACCESS_KEY_ID="clutch_access"
AWS_SECRET_ACCESS_KEY="clutch_secret"
AWS_REGION="us-east-1"
S3_BUCKET="clutch-uploads"
S3_TRAJECTORIES_BUCKET="clutch-trajectories"
S3_ENDPOINT="http://localhost:9000"
# Production (Supabase Storage): generate S3 keys in Dashboard → Storage → S3 Access Keys
# AWS_ACCESS_KEY_ID="<supabase-s3-access-key>"
# AWS_SECRET_ACCESS_KEY="<supabase-s3-secret-key>"
# S3_ENDPOINT="https://[ref].supabase.co/storage/v1/s3"

# ── Auth ──────────────────────────────────────────────────
# Local dev: custom JWT (bcrypt + jsonwebtoken). Generate secrets: openssl rand -hex 64
JWT_SECRET="clutch-dev-secret-change-in-production"
JWT_REFRESH_SECRET="clutch-dev-refresh-secret-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
# Production (Supabase Auth): set these instead of JWT_SECRET/JWT_REFRESH_SECRET.
# Find the JWT secret in Dashboard → Settings → API → JWT Secret.
# SUPABASE_JWT_SECRET="<supabase-jwt-secret>"
# SUPABASE_URL="https://[ref].supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="<supabase-service-role-key>"

# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:8080"

# ── Worker ────────────────────────────────────────────────
# Shared secret between server and Python worker (min 8 chars)
WORKER_SECRET="clutch-worker-secret-change-in-production"
API_BASE_URL="http://localhost:3001"

# ── Frontend (Vite) ──────────────────────────────────────
# These go in the root .env (not server/.env) or your deploy platform's env config.
VITE_API_URL="http://localhost:3001/api/v1"
# Production (Supabase Auth): uncomment to enable Supabase Auth on the frontend.
# When absent, the frontend falls back to custom auth (local dev mode).
# VITE_SUPABASE_URL="https://[ref].supabase.co"
# VITE_SUPABASE_ANON_KEY="eyJ..."
